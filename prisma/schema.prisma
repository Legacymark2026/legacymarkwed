generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String             @id @default(uuid())
  name                  String?
  email                 String?            @unique
  emailVerified         DateTime?          @map("email_verified")
  image                 String?
  passwordHash          String?            @map("password_hash")
  firstName             String?            @map("first_name")
  lastName              String?            @map("last_name")
  phone                 String?
  role                  String             @default("guest")
  mfaEnabled            Boolean            @default(false) @map("mfa_enabled")
  mfaSecret             String?            @map("mfa_secret")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deactivatedAt         DateTime?          @map("deactivated_at")
  adminNotes            String?            @map("admin_notes")
  customTag             String?            @map("custom_tag")
  jobTitle              String?            @map("job_title")
  backupCodes           Json?              @map("backup_codes")
  accounts              Account[]
  annotations           Annotation[]
  apiKeys               ApiKey[]
  approvedCampaigns     Campaign[]         @relation("ApprovedCampaigns")
  invitedUsers          CompanyUser[]      @relation("InvitedBy")
  companies             CompanyUser[]
  assignedConversations Conversation[]
  crmActivities         CRMActivity[]
  assignedDeals         Deal[]             @relation("AssignedDeals")
  eventParticipations   EventParticipant[]
  organizedEvents       Event[]            @relation("EventOrganizer")
  marketingEvents       MarketingEvent[]
  posts                 Post[]
  readingList           ReadingListItem[]
  sessions              Session[]
  assignedTasks         Task[]             @relation("TaskAssignee")
  createdTasks          Task[]             @relation("TaskCreator")
  activityLogs          UserActivityLog[]
  profile               UserProfile?
  createdBounties       Bounty[]           @relation("BountyCreator")
  claimedBounties       Bounty[]           @relation("BountyClaimer")
  socialPosts           SocialPost[]       @relation("SocialPostAuthor")
  approvedSocialPosts   SocialPost[]       @relation("SocialPostApprover")
  socialPostComments    SocialPostComment[]
  socialPostLogs        SocialPostLog[]

  @@index([role])
  @@index([email])
  @@map("users")
}

// ── Permisos de roles custom ───────────────────────────────
// Cada entrada define las rutas accesibles para un rol personalizado.
// Administrado por SUPER_ADMIN desde la UI de gestión de roles.
model RoleConfig {
  id            String   @id @default(uuid())
  roleName      String   @unique @map("role_name")
  allowedRoutes Json     @default("[]") @map("allowed_routes")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([roleName])
  @@map("role_configs")
}


model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model UserProfile {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  jobTitle         String? @map("job_title")
  department       String?
  bio              String?
  socialLinks      Json?   @default("{}") @map("social_links")
  preferences      Json?   @default("{\"theme\": \"system\", \"notifications\": {\"email\": true}}")
  metadata         Json?   @default("{}")
  googleAnalytics  Json?   @map("google_analytics_config")
  facebookPixel    Json?   @map("facebook_pixel_config")
  googleTagManager Json?   @map("google_tag_manager_config")
  hotjar           Json?   @map("hotjar_config")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id                      String                   @id @default(uuid())
  name                    String
  slug                    String                   @unique
  logoUrl                 String?                  @map("logo_url")
  industry                String?
  website                 String?
  subscriptionTier        String                   @default("free") @map("subscription_tier")
  subscriptionStatus      String                   @default("active") @map("subscription_status")
  createdAt               DateTime                 @default(now()) @map("created_at")
  defaultCompanySettings  Json?                    @map("default_settings")
  passwordPolicy          Json?                    @map("password_policy")
  whiteLabeling           Json?                    @map("white_labeling")
  brandKit                BrandKit?
  customObjectDefinitions CustomObjectDefinition[]
  adSpends                AdSpend[]
  apiKeys                 ApiKey[]
  campaigns               Campaign[]
  campaignAssets          CampaignAsset[]
  abTests                 ABTest[]
  members                 CompanyUser[]
  conversations           Conversation[]
  deals                   Deal[]
  emailTemplates          EmailTemplate[]
  events                  Event[]
  experiments             Experiment[]
  integrationConfigs      IntegrationConfig[]
  scoringRules            LeadScoringRule[]
  leads                   Lead[]
  marketingEvents         MarketingEvent[]
  shortLinks              ShortLink[]
  tasks                   Task[]
  teams                   Team[]
  workflows               Workflow[]
  socialPosts             SocialPost[]

  @@map("companies")
}

model BrandKit {
  id              String   @id @default(uuid())
  companyId       String   @unique @map("company_id")
  name            String   @default("Brand Kit")
  primaryColor    String   @default("#6D28D9") @map("primary_color")
  secondaryColor  String   @default("#FFFFFF") @map("secondary_color")
  accentColor     String   @default("#10B981") @map("accent_color")
  logoUrl         String?  @map("logo_url")
  fontFamily      String   @default("Inter") @map("font_family")
  toneOfVoice     String   @default("professional") @map("tone_of_voice")
  brandValues     String[] @map("brand_values")
  targetAudience  String?  @map("target_audience")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("brand_kits")
}

model CompanyUser {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  companyId   String   @map("company_id")
  role        String   @default("member")
  permissions Json?    @default("[]")
  invitedBy   String?  @map("invited_by")
  joinedAt    DateTime @default(now()) @map("joined_at")
  teamId      String?  @map("team_id")
  phoneExtension String? @map("phone_extension")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inviter     User?    @relation("InvitedBy", fields: [invitedBy], references: [id])
  team        Team?    @relation(fields: [teamId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([role])
  @@map("company_users")
}

model Team {
  id          String                   @id @default(uuid())
  name        String
  description String?
  path        String                   @default("/")
  level       Int                      @default(0)
  parentId    String?                  @map("parent_id")
  companyId   String                   @map("company_id")
  maxHeadcount Int?                    @map("max_headcount")
  monthlyBudget Float?                 @map("monthly_budget")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  permissions CustomObjectPermission[]
  members     CompanyUser[]
  bounties    Bounty[]
  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Team?                    @relation("TeamHierarchy", fields: [parentId], references: [id])
  children    Team[]                   @relation("TeamHierarchy")

  @@index([companyId])
  @@index([path])
  @@map("teams")
}

model CustomObjectDefinition {
  id                String                     @id @default(cuid())
  name              String
  label             String
  description       String?
  companyId         String
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  company           Company                    @relation(fields: [companyId], references: [id])
  fields            CustomObjectField[]
  permissions       CustomObjectPermission[]
  relationshipsFrom CustomObjectRelationship[] @relation("RelationshipFrom")
  relationshipsTo   CustomObjectRelationship[] @relation("RelationshipTo")
  records           CustomObjectRecord[]

  @@unique([companyId, name])
}

model CustomObjectField {
  id           String                 @id @default(cuid())
  name         String
  label        String
  type         String
  required     Boolean                @default(false)
  options      String?
  definitionId String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
}

model CustomObjectRelationship {
  id        String                 @id @default(cuid())
  name      String
  type      String
  fromId    String
  toId      String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  from      CustomObjectDefinition @relation("RelationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        CustomObjectDefinition @relation("RelationshipTo", fields: [toId], references: [id], onDelete: Cascade)
}

model CustomObjectPermission {
  id           String                 @id @default(cuid())
  teamId       String
  definitionId String
  canCreate    Boolean                @default(false)
  canRead      Boolean                @default(false)
  canUpdate    Boolean                @default(false)
  canDelete    Boolean                @default(false)
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  team         Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, definitionId])
}

model CustomObjectRecord {
  id           String                 @id @default(uuid())
  definitionId String                 @map("definition_id")
  data         Json
  createdBy    String?                @map("created_by")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("custom_object_records")
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("user_activity_logs")
}

model ApiKey {
  id        String   @id @default(uuid())
  name      String
  keyHash   String   @unique @map("key_hash")
  userId    String?  @map("user_id")
  companyId String?  @map("company_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Post {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  excerpt         String?
  content         String
  coverImage      String?     @map("cover_image")
  imageAlt        String?     @map("image_alt")
  published       Boolean     @default(false)
  metaTitle       String?     @map("meta_title")
  metaDescription String?     @map("meta_description")
  canonicalUrl    String?     @map("canonical_url")
  focusKeyword    String?     @map("focus_keyword")
  status          String      @default("draft")
  scheduledDate   DateTime?   @map("scheduled_date")
  authorId        String      @map("author_id")
  seriesId        String?     @map("series_id")
  seriesOrder     Int?        @map("series_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  comments        Comment[]
  likes           PostLike[]
  views           PostView[]
  author          User        @relation(fields: [authorId], references: [id])
  series          PostSeries? @relation(fields: [seriesId], references: [id])
  categories      Category[]  @relation("CategoryToPost")
  tags            Tag[]       @relation("PostToTag")

  @@index([authorId])
  @@index([seriesId])
  @@map("posts")
}

model Project {
  id                  String                @id @default(uuid())
  title               String
  slug                String                @unique
  description         String
  content             String?
  client              String?
  coverImage          String?               @map("cover_image")
  imageAlt            String?               @map("image_alt")
  gallery             Json?                 @default("[]")
  published           Boolean               @default(false)
  metaTitle           String?               @map("meta_title")
  metaDescription     String?               @map("meta_description")
  focusKeyword        String?               @map("focus_keyword")
  status              String                @default("draft")
  scheduledDate       DateTime?             @map("scheduled_date")
  featured            Boolean               @default(false)
  displayOrder        Int                   @default(0) @map("display_order")
  startDate           DateTime?             @map("start_date")
  endDate             DateTime?             @map("end_date")
  testimonial         String?
  results             Json?                 @default("[]")
  projectUrl          String?               @map("project_url")
  categoryId          String?               @map("category_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  clientLogo          String?               @map("client_logo")
  pdfUrl              String?               @map("pdf_url")
  private             Boolean               @default(false)
  seoScore            Int                   @default(0)
  team                Json?                 @default("[]")
  techStack           Json?                 @default("[]")
  videoUrl            String?               @map("video_url")
  ProjectToProjectTag ProjectToProjectTag[]
  views               ProjectView[]
  category            ProjectCategory?      @relation(fields: [categoryId], references: [id])
  services            Service[]             @relation("ProjectToService")

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@map("projects")
}

model ProjectCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[]

  @@map("project_categories")
}

model ProjectTag {
  id                  String                @id @default(uuid())
  name                String                @unique
  ProjectToProjectTag ProjectToProjectTag[]

  @@map("project_tags")
}

model ProjectView {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  ipHash    String   @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ipHash, createdAt])
  @@index([projectId])
  @@index([createdAt])
  @@map("project_views")
}

model Service {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[] @relation("ProjectToService")

  @@map("services")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostToTag")

  @@map("tags")
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("CategoryToPost")

  @@map("categories")
}

model Workflow {
  id            String              @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean             @default(false) @map("is_active")
  triggerType   String              @map("trigger_type")
  triggerConfig Json                @map("trigger_config")
  steps         Json
  companyId     String              @map("company_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  executions    WorkflowExecution[]
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(uuid())
  status      String
  logs        Json?
  workflowId  String    @map("workflow_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  currentStep Int       @default(0) @map("current_step")
  resumeAt    DateTime? @map("resume_at")
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@map("workflow_executions")
}

model Bounty {
  id          String   @id @default(uuid())
  title       String
  description String?
  rewardAmount Float    @map("reward_amount")
  status      String   @default("OPEN")
  teamId      String   @map("team_id")
  createdBy   String   @map("created_by")
  claimedBy   String?  @map("claimed_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator     User     @relation("BountyCreator", fields: [createdBy], references: [id])
  claimer     User?    @relation("BountyClaimer", fields: [claimedBy], references: [id])

  @@index([teamId])
  @@index([status])
  @@map("bounties")
}

model PostView {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  ipHash    String   @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, ipHash, createdAt])
  @@index([postId])
  @@index([createdAt])
  @@map("post_views")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  sessionId String   @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sessionId])
  @@index([postId])
  @@map("post_likes")
}

model Comment {
  id          String    @id @default(uuid())
  content     String
  authorName  String    @map("author_name")
  authorEmail String    @map("author_email")
  authorUrl   String?   @map("author_url")
  postId      String    @map("post_id")
  parentId    String?   @map("parent_id")
  approved    Boolean   @default(false)
  flagged     Boolean   @default(false)
  ipHash      String?   @map("ip_hash")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([parentId])
  @@index([approved])
  @@map("comments")
}

model NewsletterSubscription {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  source         String    @default("blog")
  confirmed      Boolean   @default(false)
  confirmToken   String?   @map("confirm_token")
  frequency      String    @default("weekly")
  interests      Json?     @default("[]")
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([confirmed])
  @@index([unsubscribed])
  @@map("newsletter_subscriptions")
}

model PostSeries {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?  @map("cover_image")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  posts       Post[]

  @@map("post_series")
}

model ReadingListItem {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  postSlug String   @map("post_slug")
  addedAt  DateTime @default(now()) @map("added_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postSlug])
  @@index([userId])
  @@map("reading_list_items")
}

model Deal {
  id            String        @id @default(uuid())
  title         String
  value         Float         @default(0)
  currency      String        @default("USD")
  stage         String        @default("NEW")
  probability   Int           @default(0)
  contactName   String?       @map("contact_name")
  contactEmail  String?       @map("contact_email")
  companyId     String        @map("company_id")
  priority      String        @default("MEDIUM")
  notes         String?
  lostReason    String?       @map("lost_reason")
  lastActivity  DateTime      @default(now()) @map("last_activity")
  tags          String[]      @default([])
  source        String?       @default("Unknown")
  expectedClose DateTime?     @map("expected_close")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  assignedTo    String?       @map("assigned_to")
  activities    CRMActivity[]
  assignedUser  User?         @relation("AssignedDeals", fields: [assignedTo], references: [id])
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events        Event[]

  @@index([companyId])
  @@index([stage])
  @@index([priority])
  @@index([assignedTo])
  @@map("deals")
}

model CRMActivity {
  id        String   @id @default(uuid())
  type      String
  content   String
  dealId    String   @map("deal_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@index([userId])
  @@index([createdAt])
  @@map("crm_activities")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime? @map("due_date")
  priority    String    @default("MEDIUM")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  dealId      String?   @map("deal_id")
  leadId      String?   @map("lead_id")
  assignedTo  String?   @map("assigned_to")
  createdBy   String    @map("created_by")
  companyId   String    @map("company_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  assignee    User?     @relation("TaskAssignee", fields: [assignedTo], references: [id])
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User      @relation("TaskCreator", fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([assignedTo])
  @@index([dealId])
  @@index([dueDate])
  @@index([completed])
  @@map("tasks")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String
  body        String
  description String?
  variables   String[] @default([])
  category    String   @default("GENERAL")
  companyId   String   @map("company_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([category])
  @@map("email_templates")
}

model LeadScoringRule {
